# ─────────────────────────────────────────────────────────
# Firebase Service Account JSON — looked up in backend/,
# then repo root. Default filename: firebase-key.json
# ─────────────────────────────────────────────────────────

FIREBASE_KEY_PATH=firebase-key.json

# Firebase project ID (matches your firebaseConfig in the frontend)
FIREBASE_PROJECT_ID=my-carbon-guide

# Port for the backend server
PORT=8000

# CORS — the URL of your React frontend
CORS_ORIGIN=http://localhost:5173

# Google Cloud Translation API key (for Hindi/Kannada translations)
# Get one at https://console.cloud.google.com/apis/credentials
GOOGLE_TRANSLATE_API_KEY=your_key_here
